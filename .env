# App Configuration
APP_NAME=CarSiGo
APP_ENV=staging
APP_KEY=base64:v0csSUhlp/4YYLNB8r7uoXBmOxJkBrevAM2PSbet1hU=
APP_DEBUG=false
APP_URL=http://192.168.20.43:8080

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=carsigo_staging
DB_USERNAME=staging_user
DB_PASSWORD=staging_password_here

# Cache Configuration
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Configuration
REDIS_HOST=192.168.20.43
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=192.168.20.43
MAIL_PORT=587
MAIL_USERNAME=staging@carsigo.com
MAIL_PASSWORD=staging_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@carsigo.com
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=staging.carsigo.com

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://staging.carsigo.com,https://app.staging.carsigo.com

# File Uploads
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=carsigo-staging
AWS_USE_PATH_STYLE_ENDPOINT=false

# Payment Configuration (Wompi)
WOMPI_PUBLIC_KEY=pub_staging_xxxx
WOMPI_PRIVATE_KEY=prv_staging_xxxx
WOMPI_EVENT_URL=https://staging.carsigo.com/api/wompi/webhook

# Pusher/Reverb Configuration
BROADCAST_DRIVER=reverb
PUSHER_APP_KEY=reverb_key
PUSHER_APP_SECRET=reverb_secret
PUSHER_APP_ID=reverb
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=192.168.20.43
PUSHER_PORT=8080
PUSHER_SCHEME=http

# Reverb Configuration
REVERB_APP_KEY=reverb_key
REVERB_APP_SECRET=reverb_secret
REVERB_APP_ID=reverb
REVERB_HOST=192.168.20.43
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_PING_INTERVAL=30
REVERB_MAX_MESSAGE_SIZE=10000
REVERB_LOG_DRIVER=single
REVERB_LOG_LEVEL=debug
REVERB_LOG_PATH=storage/logs/reverb.log

# Firebase/FCM Configuration
FCM_SERVER_KEY=AAAA_staging_fcm_key_here
FCM_SENDER_ID=1234567890_staging
FIREBASE_PROJECT_ID=carsigo-staging
FIREBASE_PRIVATE_KEY_ID=private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@carsigo-staging.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Frontend URL
FRONTEND_URL=https://staging.carsigo.com

# Google Maps
GOOGLE_MAPS_API_KEY=AIzaSy_staging_google_maps_key

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Performance
OPCACHE_ENABLED=true
APCU_ENABLED=true

# Security
BCRYPT_ROUNDS=12
HASH_DRIVER=bcrypt
